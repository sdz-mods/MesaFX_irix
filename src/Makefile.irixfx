	tnl/t_imm_alloc.c \
	tnl/t_imm_api.c \
	tnl/t_imm_debug.c \
	tnl/t_imm_dlist.c \
	tnl/t_imm_elt.c \
	tnl/t_imm_eval.c \
	tnl/t_imm_exec.c \
	tnl/t_imm_fixup.c \
	tnl/t_pipeline.c \
	tnl/t_vb_fog.c \
	tnl/t_vb_light.c \
	tnl/t_vb_normals.c \
	tnl/t_vb_points.c \
	tnl/t_vb_render.c \
	tnl/t_vb_texgen.c \
	tnl/t_vb_texmat.c \
	tnl/t_vb_vertex.c

# --------------------------------------------------------------------------
# 3Dfx Glide FX driver sources
# --------------------------------------------------------------------------
FX_SRCS = \
	FX/fxapi.c \
	FX/fxdd.c \
	FX/fxddspan.c \
	FX/fxddtex.c \
	FX/fxsetup.c \
	FX/fxtexman.c \
	FX/fxtris.c \
	FX/fxvb.c \
	FX/fxglidew.c

SRCS    = $(CORE_SRCS) $(FX_SRCS)
OBJECTS = $(SRCS:.c=.o)

# --------------------------------------------------------------------------
# GLU sources  (compiled into ../src-glu/*.o)
# --------------------------------------------------------------------------
GLU_SRCS = \
	glu.c \
	mipmap.c \
	nurbs.c \
	nurbscrv.c \
	nurbssrf.c \
	nurbsutl.c \
	polytest.c \
	project.c \
	quadric.c \
	tess.c \
	tesselat.c

GLU_OBJECTS = \
	$(GLU_SRCDIR)/glu.o \
	$(GLU_SRCDIR)/mipmap.o \
	$(GLU_SRCDIR)/nurbs.o \
	$(GLU_SRCDIR)/nurbscrv.o \
	$(GLU_SRCDIR)/nurbssrf.o \
	$(GLU_SRCDIR)/nurbsutl.o \
	$(GLU_SRCDIR)/polytest.o \
	$(GLU_SRCDIR)/project.o \
	$(GLU_SRCDIR)/quadric.o \
	$(GLU_SRCDIR)/tess.o \
	$(GLU_SRCDIR)/tesselat.o

# --------------------------------------------------------------------------
# GLUT sources  (compiled into ../src-glut-fx/*.o)
# --------------------------------------------------------------------------
GLUT_OBJECTS = $(GLUT_SRCDIR)/glut_fxmesa.o

# --------------------------------------------------------------------------
# Targets
# --------------------------------------------------------------------------
.PHONY: all clean glide-check

all: glide-check $(LIBDIR)/$(GL_LIB) $(LIBDIR)/$(GLU_LIB) $(LIBDIR)/$(GLUT_LIB)

glide-check:
	@if [ -z "$(GLIDE_ROOT)" ]; then \
	    echo ""; \
	    echo "ERROR: GLIDE_ROOT is not set."; \
	    echo "Usage: smake -f Makefile.irixfx GLIDE_ROOT=/path/to/glide_irix"; \
	    echo ""; \
	    exit 1; \
	fi

$(LIBDIR)/$(GL_LIB): $(OBJECTS)
	-mkdir $(LIBDIR)
	ar -rcv $(GL_LIB) $(OBJECTS)
	mv $(GL_LIB) $(LIBDIR)/$(GL_LIB)
	@echo ""
	@echo "  Built: $(LIBDIR)/$(GL_LIB)"

$(LIBDIR)/$(GLU_LIB): $(GLU_OBJECTS)
	-mkdir $(LIBDIR)
	ar -rcv $(GLU_LIB) $(GLU_OBJECTS)
	mv $(GLU_LIB) $(LIBDIR)/$(GLU_LIB)
	@echo ""
	@echo "  Built: $(LIBDIR)/$(GLU_LIB)"

$(LIBDIR)/$(GLUT_LIB): $(GLUT_OBJECTS)
	-mkdir $(LIBDIR)
	ar -rcv $(GLUT_LIB) $(GLUT_OBJECTS)
	mv $(GLUT_LIB) $(LIBDIR)/$(GLUT_LIB)
	@echo ""
	@echo "  Built: $(LIBDIR)/$(GLUT_LIB)"

clean:
	rm -f $(OBJECTS) $(GL_LIB) $(LIBDIR)/$(GL_LIB)
	rm -f $(GLU_OBJECTS) $(GLU_LIB) $(LIBDIR)/$(GLU_LIB)
	rm -f $(GLUT_OBJECTS) $(GLUT_LIB) $(LIBDIR)/$(GLUT_LIB)

# --------------------------------------------------------------------------
# Compile rules
# IRIX make cannot apply the .c.o suffix rule to subdirectory sources,
# so each subdirectory requires an explicit rule.
# Top-level .c files are handled by the suffix rule below.
# --------------------------------------------------------------------------
.c.o:
	$(CC) -c $(ALL_CFLAGS) $< -o $@

