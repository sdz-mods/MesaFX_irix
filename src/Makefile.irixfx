#!smake
#
# Makefile.irixfx — Mesa 3.5 FX/Glide static libraries for IRIX 6.5
#
# Run from MesaFX_irix/src/:
#   smake -f Makefile.irixfx GLIDE_ROOT=/path/to/glide_irix
#
# GLIDE_ROOT is the root of the glide_irix tree, e.g.:
#   /usr/sdd/3dfx_irix/glide_irix
#
# The following paths are derived from it automatically:
#   glide.h, sst1vid.h, etc. : $(GLIDE_ROOT)/glide2x/sst1/glide/src
#   3dfx.h                   : $(GLIDE_ROOT)/swlibs/fxmisc
#
# Outputs:
#   ../lib32/libGL.a    — Mesa core + 3Dfx FX driver
#   ../lib32/libGLU.a   — Mesa GLU utilities
#   ../lib32/libglut.a  — GLUT stub (FX/no-X11, from src-glut-fx/)
#

# --------------------------------------------------------------------------
# Required — pass on the command line:
#   smake -f Makefile.irixfx GLIDE_ROOT=/usr/sdd/3dfx_irix/glide_irix
# --------------------------------------------------------------------------
GLIDE_ROOT =
GLIDE_INC  = $(GLIDE_ROOT)/glide2x/sst1/glide/src
GLIDE_MISC = $(GLIDE_ROOT)/swlibs/fxmisc
GLIDE_INIT = $(GLIDE_ROOT)/glide2x/sst1/init

# --------------------------------------------------------------------------
# Toolchain and flags
# --------------------------------------------------------------------------
CC     = cc
CFLAGS = -n32 -mips4 -O3 -ansi -woff 1174,1209,1521

INCDIR    = ../include
LIBDIR    = ../lib32
GL_LIB    = libGL.a
GLU_LIB   = libGLU.a
GLUT_LIB  = libglut.a

GLU_SRCDIR  = ../src-glu
GLUT_SRCDIR = ../src-glut-fx

ALL_CFLAGS  = $(CFLAGS) -I. -I$(INCDIR) -I$(GLIDE_INC) -I$(GLIDE_MISC) -I$(GLIDE_INIT) -DFX
GLU_CFLAGS  = $(CFLAGS) -I$(INCDIR) -I$(GLU_SRCDIR)
GLUT_CFLAGS = $(CFLAGS) -I$(INCDIR) -I$(GLIDE_INC) -I$(GLIDE_MISC) -I$(GLIDE_INIT)

# --------------------------------------------------------------------------
# Core Mesa sources
# --------------------------------------------------------------------------
