# --------------------------------------------------------------------------
# GLU compile rules (explicit — IRIX make cannot handle ../subdir/*.o)
# Sources live in ../src-glu/; private headers resolved via -I$(GLU_SRCDIR)
# --------------------------------------------------------------------------
$(GLU_SRCDIR)/glu.o: $(GLU_SRCDIR)/glu.c
	$(CC) -c $(GLU_CFLAGS) $< -o $@
$(GLU_SRCDIR)/mipmap.o: $(GLU_SRCDIR)/mipmap.c
	$(CC) -c $(GLU_CFLAGS) $< -o $@
$(GLU_SRCDIR)/nurbs.o: $(GLU_SRCDIR)/nurbs.c
	$(CC) -c $(GLU_CFLAGS) $< -o $@
$(GLU_SRCDIR)/nurbscrv.o: $(GLU_SRCDIR)/nurbscrv.c
	$(CC) -c $(GLU_CFLAGS) $< -o $@
$(GLU_SRCDIR)/nurbssrf.o: $(GLU_SRCDIR)/nurbssrf.c
	$(CC) -c $(GLU_CFLAGS) $< -o $@
$(GLU_SRCDIR)/nurbsutl.o: $(GLU_SRCDIR)/nurbsutl.c
	$(CC) -c $(GLU_CFLAGS) $< -o $@
$(GLU_SRCDIR)/polytest.o: $(GLU_SRCDIR)/polytest.c
	$(CC) -c $(GLU_CFLAGS) $< -o $@
$(GLU_SRCDIR)/project.o: $(GLU_SRCDIR)/project.c
	$(CC) -c $(GLU_CFLAGS) $< -o $@
$(GLU_SRCDIR)/quadric.o: $(GLU_SRCDIR)/quadric.c
	$(CC) -c $(GLU_CFLAGS) $< -o $@
$(GLU_SRCDIR)/tess.o: $(GLU_SRCDIR)/tess.c
	$(CC) -c $(GLU_CFLAGS) $< -o $@
$(GLU_SRCDIR)/tesselat.o: $(GLU_SRCDIR)/tesselat.c
	$(CC) -c $(GLU_CFLAGS) $< -o $@

# --------------------------------------------------------------------------
# GLUT compile rule
# --------------------------------------------------------------------------
$(GLUT_SRCDIR)/glut_fxmesa.o: $(GLUT_SRCDIR)/glut_fxmesa.c
	$(CC) -c $(GLUT_CFLAGS) $< -o $@
